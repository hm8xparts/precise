# Public site URL — used for canonical URLs, sitemap, OG image absolute URLs.
# Set in Vercel to your production hostname (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://precisecomponents.com

# Google Analytics 4 — add a GA4 measurement ID (G-XXXXXXXXXX). Leave blank to disable.
NEXT_PUBLIC_GA_ID=

# Google Search Console — paste the meta-tag content value once verification starts.
GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools — meta-tag content value (msvalidate.01).
BING_SITE_VERIFICATION=

# Resend (transactional email — RFQ form delivery). Sign up at resend.com.
RESEND_API_KEY=
# From address must be a verified Resend sender domain.
RESEND_FROM_EMAIL=quotes@precisecomponents.com
# Where RFQ submissions land.
RESEND_TO_EMAIL=sales@precisecomponents.com
